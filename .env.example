# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your-key
CLERK_SECRET_KEY=sk_test_your-key
CLERK_WEBHOOK_SECRET=whsec_your-webhook-secret
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/auth/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/auth/cadastro
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/explorar
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/explorar

# Admin
ADMIN_EMAIL=admin
ADMIN_PASSWORD=admin123@
ADMIN_SESSION_SECRET=odd-admin-secret-key-change-in-prod

# Supabase Service Role (for cron sync - optional, falls back to anon key)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Cron
CRON_SECRET=your-cron-secret

# App
NEXT_PUBLIC_APP_URL=https://oddbr.com
